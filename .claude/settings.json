{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/lint-typecheck.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-env-leak.sh"
          }
        ]
      }
    ]
  }
}
