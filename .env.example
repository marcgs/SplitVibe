# =============================================================================
# SplitVibe — Environment Variables
# Copy to .env for local dev (also sourced by `bin/sv deploy` / `bin/sv infra`).
# =============================================================================


# --- Local dev (bin/sv serve) ----------------------------------------------

# Connection string for the Postgres started by `bin/sv up` (docker-compose).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/splitvibe"

# Auth.js v5 session secret. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Enables the mock-login buttons on /login (dev only).
ENABLE_TEST_ACCOUNTS=true

# Azure Blob Storage — pointed at the local Azurite container started by
# `bin/sv up`. The presence of AZURE_STORAGE_CONNECTION_STRING is what makes
# `lib/storage.ts` use Azurite instead of a real Azure Storage account.
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;"
AZURE_STORAGE_CONTAINER_NAME="attachments"


# --- Deployment (bin/sv infra / bin/sv deploy) -----------------------------

# Admin password for the Azure Postgres Flexible Server provisioned by infra.
POSTGRES_ADMIN_PASSWORD=""

# Auth.js secret stored in Key Vault and injected as NEXTAUTH_SECRET into the
# Container App. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Google OAuth credentials (required by deploy; optional locally — when unset,
# only the mock-login provider is registered).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Custom domains bound to the Container App. CUSTOM_DOMAIN_PROD is required
# for `bin/sv deploy prod`; CUSTOM_DOMAIN_DEV is optional.
CUSTOM_DOMAIN_DEV=""
CUSTOM_DOMAIN_PROD=""
